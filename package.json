{
	"name": "frontendv2",
	"version": "1.3.7+4",
	"license": "AGPL-3.0-or-later",
	"type": "module",
	"scripts": {
		"dev": "cross-env NODE_OPTIONS='--max-old-space-size=8192' next dev --webpack -H 127.0.0.1",
		"dev:turbo": "cross-env NODE_OPTIONS='--max-old-space-size=8192' next dev -H 127.0.0.1",
		"dev:clean": "rm -rf .next/dev && pnpm dev",
		"build": "run-s scan:translations lint build:next",
		"build:next": "next build",
		"start": "next start",
		"lint": "run-s lint:eslint lint:format",
		"lint:eslint": "eslint --fix",
		"lint:format": "prettier --log-level silent --write src/",
		"format": "run-s lint:format",
		"scan:translations": "node scripts/scan-translations.js",
		"translations:add": "node scripts/add-translation.js",
		"scan:translations:unused": "node scripts/scan-unused-translations.js",
		"fix:translations": "node scripts/fix-translation-placeholders.js",
		"export:docs": "run-s export:docs:widgets export:docs:permissions export:docs:events export:docs:api",
		"export:docs:widgets": "node scripts/export-widget-docs.js",
		"export:docs:permissions": "node scripts/export-permissions-docs.js",
		"export:docs:events": "node scripts/export-events-docs.js",
		"export:docs:api": "node scripts/export-api-docs.js"
	},
	"dependencies": {
		"@hcaptcha/react-hcaptcha": "^2.0.2",
		"@headlessui/react": "^2.2.10",
		"@monaco-editor/react": "4.8.0-rc.3",
		"@radix-ui/react-progress": "^1.1.9",
		"@radix-ui/react-slot": "^1.2.5",
		"@radix-ui/react-switch": "^1.3.0",
		"@radix-ui/react-tabs": "^1.1.14",
		"@react-three/drei": "^10.7.7",
		"@react-three/fiber": "^9.6.1",
		"@simplewebauthn/browser": "13.3.0",
		"@tailwindcss/typography": "^0.5.20",
		"@types/js-yaml": "^4.0.9",
		"@types/react-google-recaptcha": "^2.1.9",
		"@xterm/addon-attach": "^0.12.0",
		"@xterm/addon-clipboard": "^0.2.0",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/addon-image": "^0.9.0",
		"@xterm/addon-search": "^0.16.0",
		"@xterm/addon-web-links": "^0.12.0",
		"@xterm/addon-webgl": "^0.19.0",
		"@xterm/xterm": "^6.0.0",
		"axios": "^1.17.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.4.0",
		"date-fns-tz": "^3.2.0",
		"js-yaml": "^4.2.0",
		"lucide-react": "^1.17.0",
		"next": "16.2.7",
		"ogl": "^1.0.11",
		"prettier": "^3.8.4",
		"prettier-plugin-tailwindcss-canonical-classes": "^0.1.5",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-google-recaptcha": "^3.1.0",
		"react-markdown": "^10.1.0",
		"react-qr-code": "^2.2.0",
		"react-turnstile": "^1.1.5",
		"recharts": "^3.8.1",
		"remark-gfm": "^4.0.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"three": "^0.184.0",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4",
		"@types/node": "^25",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"babel-plugin-react-compiler": "1.0.0",
		"eslint": "^9",
		"eslint-config-next": "16.2.7",
		"eslint-config-prettier": "^10.1.8",
		"npm-run-all": "^4.1.5",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"tailwindcss": "^4",
		"typescript": "^6.0.3",
		"cross-env": "^7.0.3"
	}
}